---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ProgramCard from '../components/ProgramCard.astro';
import VideoModal from '../components/VideoModal.astro';
import BookingModal from '../components/BookingModal.astro';
import HowStep from '../components/HowStep.astro';
import CinematicImage from '../components/CinematicImage.astro';

// Data-driven content (Phase 1 foundation — easy to update, no hardcodes)
import programsData from '../data/programs.json';
import videosData from '../data/videos.json';
import testimonialsData from '../data/testimonials.json';

import type { Program, Video, Testimonial } from '../types/content';

// Typed for client script consumption
const programs = programsData as unknown as Program[];
const videos = videosData as unknown as Video[];
const testimonials = testimonialsData as unknown as Testimonial[];
---

<Layout title="Saad & Danial | Study in Germany — Real Guidance for Pakistani Students">
  <Navbar />

  <!-- ==================== HERO — Cinematic "Clarity Veil" (Signature Editorial Reveal) ==================== -->
  <section class="relative overflow-hidden bg-[#0A1F44] text-white pt-16 pb-20 md:pt-20 md:pb-24 border-b-4 border-[#FFDD00] cinematic-hero">
    <!-- Subtle film veil / grain for cinematic depth (fixed, pointer-events-none) -->
    <div class="absolute inset-0 pointer-events-none z-0 opacity-40" style="background-image: linear-gradient(rgba(0,0,0,0.04) 1px, transparent 1px), linear-gradient(90deg, rgba(0,0,0,0.04) 1px, transparent 1px); background-size: 4px 4px; mix-blend-mode: multiply;"></div>
    <div class="max-w-5xl mx-auto px-5 sm:px-6 text-center relative z-10">
      <!-- Trust badge -->
      <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur px-5 h-9 rounded-3xl text-xs font-bold tracking-[2px] mb-7 border border-white/20">
        <span class="w-1.5 h-1.5 bg-[#FFDD00] rounded-full animate-pulse"></span>
        25,400+ STUDENTS • 3+ YEARS DOCUMENTING THE JOURNEY
      </div>

      <h1 class="heading-xl tracking-[-3.8px] leading-[0.9] mb-6 cinematic-hero-headline">
        <span class="hero-word">From Pakistan.</span><br />
        <span class="hero-word text-[#FFDD00]">To Germany.</span><br />
        <span class="hero-word">With clarity.</span>
      </h1>

      <p class="max-w-[42ch] mx-auto text-xl md:text-2xl text-white/80 tracking-tight mb-10">
        No generic advice. No middlemen.<br class="hidden sm:block" />
        Honest guidance from two Pakistani students who made it — and documented everything.
      </p>

      <div class="flex flex-col sm:flex-row gap-3.5 justify-center items-center">
        <button 
          onclick="window.openBookingModal && window.openBookingModal()"
          class="btn btn-gold px-9 py-4 text-base shadow-lg w-full sm:w-auto">
          BOOK YOUR FREE STRATEGY CALL
        </button>
        <a href="#youtube" 
           class="btn btn-outline border-white/70 text-white hover:bg-white hover:text-[#0A1F44] px-8 py-4 w-full sm:w-auto">
          WATCH OUR LATEST VLOG
        </a>
      </div>

      <div class="mt-9 flex justify-center gap-8 text-xs text-white/60 tracking-widest font-medium">
        <div>340+ CALLS COMPLETED</div>
        <div>87% ENROLLED</div>
        <div class="hidden sm:block">4 CITIES IN PAKISTAN</div>
      </div>
    </div>

    <!-- Subtle decorative element -->
    <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[110%] h-[2px] bg-gradient-to-r from-transparent via-[#FFDD00]/30 to-transparent"></div>
  </section>

  <!-- ==================== MEET THE GUIDES (Refined photo presence) ==================== -->
  <section class="max-w-7xl mx-auto px-5 sm:px-6 pt-14 pb-8">
    <div class="grid md:grid-cols-12 gap-8 items-center">
      <div class="md:col-span-5">
        <div class="section-label">THE PEOPLE BEHIND THE GUIDANCE</div>
        <h3 class="heading-lg tracking-[-1.5px] text-[#0A1F44] mt-2 mb-4">Saad &amp; Danial.<br />We've been exactly where you are.</h3>
        <p class="text-[#475569] pr-2">Two friends from Karachi who moved to Germany for studies. We documented every expensive mistake, every visa win, and every "how is this even possible" moment so you don't have to repeat them.</p>
        
        <div class="mt-6 flex gap-3">
          <button onclick="window.openBookingModal && window.openBookingModal()" class="btn btn-gold px-6 py-2.5 text-sm">TALK TO US DIRECTLY</button>
          <a href="#youtube" class="btn btn-ghost px-4 py-2.5 text-sm">Watch our story →</a>
        </div>
      </div>

      <div class="md:col-span-7">
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
          <CinematicImage src="/images/saad-danial-1.jpg" alt="Saad & Danial at the Berlin Wall — early days in Germany" aspect="4/4.7" />
          <CinematicImage src="/images/saad-danial-2.jpg" alt="Saad & Danial at a mountain viewpoint in Austria during a break from studies" aspect="4/4.7" />
          <CinematicImage src="/images/saad-danial-3.jpg" alt="Saad & Danial reviewing footage for the YouTube channel that would help thousands" aspect="4/4.7" />
          <CinematicImage src="/images/saad-danial-4.jpg" alt="Saad & Danial on a European street — the journey documented in real time" aspect="4/4.7" />
        </div>
        <!-- Editorial filmstrip captions (developed photo essay feel) -->
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mt-2 text-[10px] text-[#475569] tracking-[0.5px] font-medium">
          <div class="px-1 cinematic-reveal">Berlin Wall • 2022</div>
          <div class="px-1 cinematic-reveal">Tyrol Alps • 2023</div>
          <div class="px-1 cinematic-reveal">Editing Suite • 2024</div>
          <div class="px-1 cinematic-reveal">Munich Streets • 2025</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== WHY GERMANY ==================== -->
  <section id="why" class="max-w-7xl mx-auto px-5 sm:px-6 pt-20 pb-16">
    <SectionHeader 
      label="WHY THOUSANDS OF PAKISTANI STUDENTS CHOOSE GERMANY" 
      title="The smartest move you can make" 
      description="World-class education at near-zero cost, 18-month post-study work visa, and a clear path to long-term residency."
      align="center"
    />

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 mt-12">
      {[
        { 
          icon: <svg class="w-7 h-7 text-[#0D5C63] opacity-80" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.75"><path stroke-linecap="round" stroke-linejoin="round" d="M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14zm-4 6v-7.5l4-2.222" /></svg>, 
          title: "Tuition-Free or Low-Cost", 
          desc: "Most public universities charge €0–€3,000 per semester. Quality that rivals UK & USA at 1/5th the cost." 
        },
        { 
          icon: <svg class="w-7 h-7 text-[#0D5C63] opacity-80" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.75"><path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" /></svg>, 
          title: "18-Month Job Seeker Visa", 
          desc: "Stay after graduation to find work. Strong demand in engineering, IT, healthcare, and logistics." 
        },
        { 
          icon: <svg class="w-7 h-7 text-[#0D5C63] opacity-80" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.75"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1v-5.5M19 10v10a1 1 0 01-1 1h-2m-6 0a1 1 0 001-1v-5m0 5v5a1 1 0 01-1 1H9m4 0H9" /></svg>, 
          title: "Clear Path to PR", 
          desc: "After 2 years of skilled work you can apply for permanent residency. Many Pakistanis have done it." 
        },
        { 
          icon: <svg class="w-7 h-7 text-[#0D5C63] opacity-80" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.75"><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" /></svg>, 
          title: "English-Taught Programs", 
          desc: "1,500+ Master's programs taught entirely in English. No German required to start studying." 
        },
        { 
          icon: <svg class="w-7 h-7 text-[#0D5C63] opacity-80" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.75"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 01-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" /></svg>, 
          title: "Large Pakistani Community", 
          desc: "Thriving student networks in Berlin, Munich, Frankfurt, Hamburg. You won't feel alone." 
        },
        { 
          icon: <svg class="w-7 h-7 text-[#0D5C63] opacity-80" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.75"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" /></svg>, 
          title: "High ROI & Safety", 
          desc: "Germany ranks among safest countries. Excellent healthcare, public transport, and work-life balance." 
        }
      ].map((b, i) => (
        <div class="card p-6 group" data-aos-delay={i * 40}>
          <div class="mb-4">{b.icon}</div>
          <h4 class="font-bold text-lg tracking-tight mb-2 text-[#0A1F44]">{b.title}</h4>
          <p class="text-sm leading-relaxed text-[#475569]">{b.desc}</p>
        </div>
      ))}
    </div>

    <div class="text-center mt-9">
      <button onclick="window.openBookingModal && window.openBookingModal()" 
              class="text-sm font-bold text-[#0D5C63] hover:text-[#0A1F44] inline-flex items-center gap-1 group">
        NOT SURE IF GERMANY IS RIGHT FOR YOU? TALK TO US FREE 
        <span class="group-hover:translate-x-0.5 transition">→</span>
      </button>
    </div>
  </section>

  <!-- ==================== POPULAR PROGRAMS (Filterable) ==================== -->
  <section id="programs" class="bg-[#F8FAFC] border-y border-[#E2E8F0] py-16">
    <div class="max-w-7xl mx-auto px-5 sm:px-6">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-8">
        <SectionHeader 
          label="CURATED PATHWAYS" 
          title="Popular programs for Pakistani students" 
        />
        <div class="text-xs text-[#475569] md:pb-1">Updated for 2026 intake cycle</div>
      </div>

      <!-- Filter Pills -->
      <div id="program-filters" class="flex flex-wrap gap-2 mb-8">
        <button class="filter-pill active" data-filter="all">All Pathways</button>
        <button class="filter-pill" data-filter="masters">Master's</button>
        <button class="filter-pill" data-filter="bachelors">Bachelor's</button>
        <button class="filter-pill" data-filter="ausbildung">Ausbildung</button>
        <button class="filter-pill" data-filter="engineering">Engineering & Tech</button>
      </div>

      <div id="programs-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        <!-- Populated by JS from programsData + ProgramCard partials for SSR feel -->
      </div>

      <p class="text-center text-xs text-[#64748B] mt-8">These are real programs our community has successfully entered. Your situation is unique — book a call for tailored shortlist.</p>
    </div>
  </section>

  <!-- ==================== SUCCESS STORIES ==================== -->
  <section id="stories" class="max-w-7xl mx-auto px-5 sm:px-6 py-20">
    <SectionHeader 
      label="REAL STUDENTS. REAL RESULTS." 
      title="They watched. They asked. They went." 
      description="Every single one of these students started exactly where you are — watching our videos from Pakistan."
      align="center"
    />

    <div class="grid md:grid-cols-3 gap-5 mt-11">
      <!-- Testimonial 1 -->
      <div class="card p-7">
        <div class="flex gap-3 mb-5">
          <div class="w-11 h-11 bg-[#0A1F44] text-white rounded-2xl flex items-center justify-center font-black text-sm flex-shrink-0">AK</div>
          <div>
            <div class="font-bold">Ayesha Khan</div>
            <div class="text-xs text-[#0D5C63]">Lahore → TU Darmstadt • MSc Data Science</div>
          </div>
        </div>
        <blockquote class="text-[15px] leading-relaxed text-[#334155]">
          “Saad’s video on the blocked account literally saved my application. I was about to send the wrong documents. Got my visa in 34 days after our call.”
        </blockquote>
        <div class="mt-6 pt-5 border-t text-xs font-bold tracking-widest text-[#0D5C63]">MASTER'S 2025 • FULLY FUNDED</div>
      </div>

      <!-- Testimonial 2 + Video -->
      <div class="card p-7 flex flex-col">
        <div class="flex gap-3 mb-5">
          <div class="w-11 h-11 bg-[#FFDD00] text-[#0A1F44] rounded-2xl flex items-center justify-center font-black text-sm flex-shrink-0">HM</div>
          <div>
            <div class="font-bold">Hamza Malik</div>
            <div class="text-xs text-[#0D5C63]">Karachi → Siemens • Ausbildung Mechatronics</div>
          </div>
        </div>
        <blockquote class="text-[15px] leading-relaxed text-[#334155] flex-1">
          “I thought Ausbildung was only for Germans. After one call with Danial I had the exact checklist. Started my training in Nuremberg 8 months later.”
        </blockquote>

        <button 
          onclick="window.openVideoModal && window.openVideoModal('auYySwMaaXU', 'How We Came To Germany From Pakistan', 'https://www.youtube.com/watch?v=auYySwMaaXU')"
          class="mt-6 group flex items-center gap-3 text-left text-sm font-semibold text-[#0D5C63] hover:text-[#0A1F44]">
          <span class="inline-flex items-center justify-center w-8 h-8 bg-[#0A1F44] group-hover:bg-[#FFDD00] group-hover:text-[#0A1F44] text-white rounded-full transition">▶</span>
          <span>WATCH HIS FULL STORY (12 min)</span>
        </button>
      </div>

      <!-- Testimonial 3 -->
      <div class="card p-7">
        <div class="flex gap-3 mb-5">
          <div class="w-11 h-11 bg-[#0D5C63] text-white rounded-2xl flex items-center justify-center font-black text-sm flex-shrink-0">SZ</div>
          <div>
            <div class="font-bold">Sara Zafar</div>
            <div class="text-xs text-[#0D5C63]">Islamabad → RWTH Aachen • BSc Mechanical Eng</div>
          </div>
        </div>
        <blockquote class="text-[15px] leading-relaxed text-[#334155]">
          “My parents were terrified of the cost. After watching 40+ of their videos I realized public universities in Germany are basically free. Changed our entire family’s future.”
        </blockquote>
        <div class="mt-6 pt-5 border-t text-xs font-bold tracking-widest text-[#0D5C63]">BACHELOR'S 2024 • SCHOLARSHIP WINNER</div>
      </div>
    </div>

    <div class="text-center mt-9">
      <a href="https://www.youtube.com/@saadanddanial9" target="_blank" class="inline-flex items-center text-sm font-bold text-[#0D5C63] hover:underline">
        SEE 100+ MORE STORIES ON OUR CHANNEL →
      </a>
    </div>
  </section>

  <!-- ==================== HOW IT WORKS ==================== -->
  <section id="how" class="bg-[#0A1F44] text-white py-16">
    <div class="max-w-6xl mx-auto px-5 sm:px-6">
      <div class="max-w-2xl mb-10">
        <div class="section-label text-[#FFDD00] tracking-[3px]">NO GUESSWORK. NO REGRETS.</div>
        <h2 class="heading-lg tracking-[-1.8px] mt-2">Exactly how we help you get to Germany</h2>
      </div>

      <div class="grid md:grid-cols-5 gap-x-4 gap-y-8">
        <HowStep number={1} title="Watch & Learn" desc="100+ free videos covering every step: visas, blocked accounts, motivation letters, city guides, and real costs." time="Start today" />
        <HowStep number={2} title="Book a Call" desc="Free 20-minute strategy session. We ask about your grades, budget, timeline and tell you honestly what’s realistic." time="20 min" />
        <HowStep number={3} title="Personal Roadmap" desc="You receive a custom document with 5 target programs, exact deadlines, required tests, and document checklist." time="Within 48h" />
        <HowStep number={4} title="Application Support" desc="We review your CV, motivation letter, and uni choices. Many students get in on the first try after our feedback." time="Ongoing" />
        <HowStep number={5} title="Pre-Departure & Arrival" desc="WhatsApp group for your intake, packing list, first-month survival guide, and introductions to Pakistanis already there." time="Before you fly" />
      </div>

      <div class="mt-10 text-center">
        <button onclick="window.openBookingModal && window.openBookingModal()" 
                class="btn btn-gold px-8 py-3.5 text-sm">START WITH A FREE CALL — NO OBLIGATION</button>
      </div>
    </div>
  </section>

  <!-- ==================== YOUTUBE HIGHLIGHTS (Beautiful Integration) ==================== -->
  <section id="youtube" class="max-w-7xl mx-auto px-5 sm:px-6 py-20">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between mb-8 gap-y-3">
      <SectionHeader 
        label="THE CONTENT THAT STARTED IT ALL" 
        title="Learn by watching real life" 
      />
      <a href="https://www.youtube.com/@saadanddanial9" target="_blank" 
         class="btn btn-gold hidden md:inline-flex px-6 py-2.5 text-sm">SUBSCRIBE ON YOUTUBE</a>
    </div>

    <p class="max-w-2xl text-[#475569] mb-8">Every hurdle we hit — visa rejection scares, finding housing, surviving on €800/month — we filmed. Thousands of Pakistani students have used these videos as their blueprint.</p>

    <!-- Featured + Grid -->
    <div class="grid lg:grid-cols-5 gap-4">
      <!-- Featured large -->
      <div class="lg:col-span-3">
        <div class="video-thumb group cursor-pointer" 
             onclick="window.openVideoModal && window.openVideoModal('GdBubpZBQpY', 'A Real Day in the Life of a Broke Student in Germany', 'https://www.youtube.com/watch?v=GdBubpZBQpY')">
          <img src="https://img.youtube.com/vi/GdBubpZBQpY/maxresdefault.jpg" 
               alt="A Real Day in the Life of a Broke Student in Germany" 
               class="w-full h-full object-cover" loading="lazy" />
          <div class="play-btn">
            <span class="ml-0.5">▶</span>
          </div>
          <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/80 via-black/60 to-transparent p-5">
            <div class="font-bold text-white text-xl tracking-tight">A Real Day in the Life of a Broke Student in Germany</div>
            <div class="text-white/70 text-xs mt-1 flex items-center gap-2">12 min • 14K views • Most watched</div>
          </div>
        </div>
      </div>

      <!-- Side videos -->
      <div class="lg:col-span-2 grid grid-rows-2 gap-4">
        <div class="video-thumb group cursor-pointer relative" 
             onclick="window.openVideoModal && window.openVideoModal('kRHX6n4fTF4', 'Stopped at German Immigration | Part 2', 'https://www.youtube.com/watch?v=kRHX6n4fTF4')">
          <img src="https://img.youtube.com/vi/kRHX6n4fTF4/maxresdefault.jpg" alt="Stopped at German Immigration" class="w-full h-full object-cover" loading="lazy" />
          <div class="play-btn scale-75">
            <span>▶</span>
          </div>
          <div class="absolute bottom-0 left-0 p-4 text-white">
            <div class="font-semibold text-sm leading-tight">Stopped at German Immigration — What We Did Wrong</div>
            <div class="yt-meta mt-0.5">71K views • 8 min</div>
          </div>
        </div>

        <div class="video-thumb group cursor-pointer relative" 
             onclick="window.openVideoModal && window.openVideoModal('auYySwMaaXU', 'How We Came To Germany From Pakistan Ep.1', 'https://www.youtube.com/watch?v=auYySwMaaXU')">
          <img src="https://img.youtube.com/vi/auYySwMaaXU/maxresdefault.jpg" alt="How We Came To Germany" class="w-full h-full object-cover" loading="lazy" />
          <div class="play-btn scale-75">
            <span>▶</span>
          </div>
          <div class="absolute bottom-0 left-0 p-4 text-white">
            <div class="font-semibold text-sm leading-tight">How We Came To Germany From Pakistan — Full Story</div>
            <div class="yt-meta mt-0.5">25K views • 19 min</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Additional video row for stronger YouTube integration -->
    <div class="mt-4 grid grid-cols-2 md:grid-cols-4 gap-4">
      <div class="video-thumb group cursor-pointer relative overflow-hidden rounded-2xl" 
           onclick="window.openVideoModal && window.openVideoModal('GdBubpZBQpY', 'Day in the Life of a Broke Student', 'https://www.youtube.com/watch?v=GdBubpZBQpY')">
        <img src="https://img.youtube.com/vi/GdBubpZBQpY/hqdefault.jpg" alt="Day in the Life" class="w-full aspect-video object-cover" loading="lazy" />
        <div class="play-btn !w-9 !h-9 text-sm"><span>▶</span></div>
        <div class="absolute bottom-0 left-0 p-3 text-white text-xs font-medium bg-gradient-to-t from-black/70">Day in the Life • Broke Student</div>
      </div>
      <div class="video-thumb group cursor-pointer relative overflow-hidden rounded-2xl" 
           onclick="window.openVideoModal && window.openVideoModal('auYySwMaaXU', 'How We Came From Pakistan', 'https://www.youtube.com/watch?v=auYySwMaaXU')">
        <img src="https://img.youtube.com/vi/auYySwMaaXU/hqdefault.jpg" alt="How We Came" class="w-full aspect-video object-cover" loading="lazy" />
        <div class="play-btn !w-9 !h-9 text-sm"><span>▶</span></div>
        <div class="absolute bottom-0 left-0 p-3 text-white text-xs font-medium bg-gradient-to-t from-black/70">Our Full Journey • Ep 1</div>
      </div>
      <div class="video-thumb group cursor-pointer relative overflow-hidden rounded-2xl hidden md:block" 
           onclick="window.openVideoModal && window.openVideoModal('kRHX6n4fTF4', 'German Immigration Story', 'https://www.youtube.com/watch?v=kRHX6n4fTF4')">
        <img src="https://img.youtube.com/vi/kRHX6n4fTF4/hqdefault.jpg" alt="Immigration" class="w-full aspect-video object-cover" loading="lazy" />
        <div class="play-btn !w-9 !h-9 text-sm"><span>▶</span></div>
        <div class="absolute bottom-0 left-0 p-3 text-white text-xs font-medium bg-gradient-to-t from-black/70">Immigration Stopped Us</div>
      </div>
      <div class="video-thumb group cursor-pointer relative overflow-hidden rounded-2xl hidden md:block" 
           onclick="window.openVideoModal && window.openVideoModal('GdBubpZBQpY', 'More Student Life', 'https://www.youtube.com/watch?v=GdBubpZBQpY')">
        <img src="https://img.youtube.com/vi/GdBubpZBQpY/hqdefault.jpg" alt="More" class="w-full aspect-video object-cover" loading="lazy" />
        <div class="play-btn !w-9 !h-9 text-sm"><span>▶</span></div>
        <div class="absolute bottom-0 left-0 p-3 text-white text-xs font-medium bg-gradient-to-t from-black/70">Housing &amp; Daily Struggles</div>
      </div>
    </div>

    <div class="mt-5 text-center md:text-right">
      <a href="https://www.youtube.com/@saadanddanial9/videos" target="_blank" 

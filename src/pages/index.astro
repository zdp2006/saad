  <!-- Pass data-driven content to client scripts (no duplication) -->
  <script define:vars={{ programs, videos, testimonials }}>
    window.__PROGRAMS = programs;
    window.__VIDEOS = videos;
    window.__TESTIMONIALS = testimonials;
  </script>

  <!-- ==================== PAGE SCRIPTS (GSAP + Filters + Interactions) ==================== -->
  <script>
    // Data now sourced from imported JSON (Phase 1) — window.__PROGRAMS etc.
    const programsData = window.__PROGRAMS || [];

    // Render program cards
    function renderPrograms(filter = 'all') {
      const grid = document.getElementById('programs-grid');
      if (!grid) return;

      grid.innerHTML = '';

      const filtered = filter === 'all' 
        ? programsData 
        : programsData.filter(p => p.category === filter || (filter === 'engineering' && p.category === 'engineering'));

      filtered.forEach(prog => {
        // Create card HTML (mirrors ProgramCard component)
        const cardHTML = `
          <div class="program-card card group p-6 flex flex-col h-full" data-category="${prog.category}" data-id="${prog.id}">
            <div class="flex items-start justify-between mb-4">
              <div><span class="badge uppercase tracking-widest">${prog.level}</span></div>
              <div class="text-right"><div class="text-xs text-[#0D5C63] font-bold tracking-wider">${prog.duration}</div></div>
            </div>
            <h3 class="font-bold text-xl leading-tight tracking-[-0.3px] mb-2 text-[#0A1F44] group-hover:text-[#0D5C63] transition-colors">${prog.title}</h3>
            <div class="text-sm text-[#475569] mb-3">${prog.unis}</div>
            <div class="mt-auto pt-4 border-t border-[#F1F5F9]">
              <div class="flex items-baseline gap-2 mb-2">
                <span class="text-lg font-bold text-[#0D5C63]">${prog.cost}</span>
              </div>
              <p class="text-xs text-[#475569] leading-snug mb-4 min-h-[2.6em]">${prog.highlight}</p>
              <button onclick="window.selectProgramAndBook && window.selectProgramAndBook(${prog.id}, '${prog.title.replace(/'/g, "\\'")}')" 
                      class="btn btn-outline w-full text-sm py-2.5 group-hover:bg-[#0A1F44] group-hover:text-white group-hover:border-[#0A1F44]">
                Get Personalized Guidance
              </button>
            </div>
          </div>
        `;
        grid.insertAdjacentHTML('beforeend', cardHTML);
      });
    }

    // Filter logic
    function initProgramFilters() {
      const filterContainer = document.getElementById('program-filters');
      if (!filterContainer) return;

      filterContainer.addEventListener('click', (e) => {
        const btn = e.target.closest('.filter-pill');
        if (!btn) return;

        // Active state
        filterContainer.querySelectorAll('.filter-pill').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');

        const filter = btn.dataset.filter;
        renderPrograms(filter);

        // Subtle animation on filter change
        const grid = document.getElementById('programs-grid');
        if (grid && typeof gsap !== 'undefined') {
          gsap.fromTo(grid.children, 
            { opacity: 0, y: 12 }, 
            { opacity: 1, y: 0, duration: 0.4, stagger: 0.035, ease: "power2.out" }
          );
        }
      });

      // Initial render
      renderPrograms('all');
    }

    // Global helper called from ProgramCard buttons
    window.selectProgramAndBook = function(programId, programTitle) {
      window.openBookingModal && window.openBookingModal(programTitle);
    };

    // ==================== GSAP ANIMATIONS (Awwwards polish) ====================
    function initGSAPAnimations() {
      if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') {
        // Retry once
        setTimeout(initGSAPAnimations, 180);
        return;
      }

      const { gsap, ScrollTrigger } = window;

      // Section reveals
      gsap.utils.toArray('section').forEach((section, i) => {
        gsap.from(section, {
          scrollTrigger: { trigger: section, start: "top 82%" },
          y: 35,
          opacity: 0.0,
          duration: 0.85,
          ease: "power3.out",
          delay: i < 2 ? 0 : 0.04
        });
      });

      // Why Germany cards stagger
      gsap.utils.toArray('#why .card').forEach((card, i) => {
        gsap.from(card, {
          scrollTrigger: { trigger: card, start: "top 88%" },
          y: 28,
          opacity: 0,
          duration: 0.65,
          ease: "power2.out",
          delay: i * 0.035
        });
      });

      // Program cards on initial load (after render)
      setTimeout(() => {
        const progCards = document.querySelectorAll('#programs-grid .program-card');
        if (progCards.length) {
          gsap.from(progCards, {
            scrollTrigger: { trigger: '#programs-grid', start: "top 80%" },
            y: 30,
            opacity: 0,
            duration: 0.6,
            stagger: 0.05,
            ease: "power2.out"
          });
        }
      }, 420);

      // Success story cards
      gsap.utils.toArray('#stories .card').forEach((card, i) => {
        gsap.from(card, {
          scrollTrigger: { trigger: card, start: "top 85%" },
          y: 25,
          opacity: 0,
          duration: 0.55,
          ease: "power3.out",
          delay: i * 0.08
        });
      });

      // Magnetic CTA buttons (refined from original)
      document.querySelectorAll('.btn-gold, .btn-primary').forEach(btn => {
        btn.addEventListener('mousemove', (e) => {
          const rect = btn.getBoundingClientRect();
          const x = ((e.clientX - rect.left) / rect.width - 0.5) * 2;
          const y = ((e.clientY - rect.top) / rect.height - 0.5) * 2;
          gsap.to(btn, { x: x * 5, y: y * 4, duration: 0.35, ease: "power2.out" });
        });
        btn.addEventListener('mouseleave', () => {
          gsap.to(btn, { x: 0, y: 0, duration: 0.65, ease: "elastic.out(1, 0.45)" });
        });
      });

      // Video thumb hover lift (subtle)
      document.querySelectorAll('.video-thumb').forEach(thumb => {
        thumb.addEventListener('mouseenter', () => gsap.to(thumb, { scale: 1.008, duration: 0.4, ease: "power2.out" }));
        thumb.addEventListener('mouseleave', () => gsap.to(thumb, { scale: 1, duration: 0.5, ease: "power2.out" }));
      });
    }

    // ==================== MISC ENHANCEMENTS ====================
    function initSmoothAnchorScroll() {
      document.querySelectorAll('a[href^="#"]').forEach(anchor => {
        anchor.addEventListener('click', function(e) {
          const target = document.querySelector(this.getAttribute('href'));
          if (target) {
            e.preventDefault();
            const offset = 80;
            const top = target.getBoundingClientRect().top + window.scrollY - offset;
            window.scrollTo({ top, behavior: 'smooth' });
          }
        });
      });
    }

    function initKeyboardShortcuts() {
      document.addEventListener('keydown', (e) => {
        // Press "b" or "B" to open booking
        if ((e.key === 'b' || e.key === 'B') && !['INPUT', 'TEXTAREA'].includes(document.activeElement.tagName)) {
          e.preventDefault();
          window.openBookingModal && window.openBookingModal();
        }
      });
    }

    // Expose openBooking for any legacy or external
    window.openBookingModal = window.openBookingModal || function(p) {
      const modal = document.getElementById('booking-modal');
      if (modal) {
        modal.classList.add('open');
        modal.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
      }
    };

    // ==================== BOOT ====================
    function boot() {
      initProgramFilters();
      initGSAPAnimations();
      initSmoothAnchorScroll();
      initKeyboardShortcuts();

      // Cinematic Hero Reveal (Signature #1) — Emil-compliant: 520-650ms, stagger 38ms, only transform + opacity
      setTimeout(() => {
        if (typeof gsap !== 'undefined') {
          const words = document.querySelectorAll('.cinematic-hero .hero-word');
          if (words.length) {
            gsap.from(words, {
              y: 24,
              opacity: 0,
              duration: 0.62,
              ease: "power3.out",
              stagger: 0.038,
              delay: 0.12
            });
          }
        }
      }, 90);

      // Easter egg: Konami-ish for booking (up up down down left right)
      let keys = [];
      const konami = [38,38,40,40,37,39];
      document.addEventListener('keyup', (e) => {
        keys.push(e.keyCode);
        if (keys.length > 6) keys.shift();
        if (keys.join(',') === konami.join(',')) {
          keys = [];
          const btn = document.querySelector('.btn-gold');
          if (btn) btn.click();
        }
      });

      console.log('%c[Saad & Danial] Premium Awwwards-inspired site initialized.', 'color:#64748B;font-size:9px');
    }

    document.addEventListener('DOMContentLoaded', boot);
  </script>
</Layout>

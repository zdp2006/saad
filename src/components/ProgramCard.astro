---
// Premium program card - filterable, conversion focused
interface Props {
  id: number;
  category: string;
  title: string;
  unis: string;
  duration: string;
  cost: string;
  level: string;
  highlight: string;
}

const { id, category, title, unis, duration, cost, level, highlight } = Astro.props;
---

<div 
  class="program-card card group p-6 flex flex-col h-full"
  data-category={category}
  data-id={id}
>
  <div class="flex items-start justify-between mb-4">
    <div>
      <span class="badge uppercase tracking-widest">{level}</span>
    </div>
    <div class="text-right">
      <div class="text-xs text-[#0D5C63] font-bold tracking-wider">{duration}</div>
    </div>
  </div>

  <h3 class="font-bold text-xl leading-tight tracking-[-0.3px] mb-2 text-[#0A1F44] group-hover:text-[#0D5C63] transition-colors">
    {title}
  </h3>
  
  <div class="text-sm text-[#475569] mb-3">{unis}</div>

  <div class="mt-auto pt-4 border-t border-[#F1F5F9]">
    <div class="flex items-baseline gap-2 mb-2">
      <span class="text-lg font-bold text-[#0D5C63]">{cost}</span>
    </div>
    <p class="text-xs text-[#475569] leading-snug mb-4 min-h-[2.6em]">
      {highlight}
    </p>

    <button 
      onclick={`window.selectProgramAndBook && window.selectProgramAndBook(${id}, '${title.replace(/'/g, "\\'")}')`}
      class="btn btn-outline w-full text-sm py-2.5 group-hover:bg-[#0A1F44] group-hover:text-white group-hover:border-[#0A1F44]">
      Get Personalized Guidance
    </button>
  </div>
</div>
